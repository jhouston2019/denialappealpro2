# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (use Test mode keys only for local / staging: pk_test_… and sk_test_…)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` locally, or Dashboard webhook signing secret in production
STRIPE_WEBHOOK_SECRET=whsec_...

# Local UI testing only — must stay false/unset in production (middleware blocks if set in prod)
# BYPASS_PAYMENT=true

# Optional: scripts/seed-test-user.mjs
# TEST_USER_EMAIL=dev-test@estimatereviewpro.local
# TEST_USER_PASSWORD=DevTestPassword123!

# Stripe Price IDs (amounts come from Stripe — set each to your Dashboard price_… id)
# Product ids (prod_…) also work — the product's default_price is used.
STRIPE_PRICE_SINGLE_REVIEW=price_... # Single Review — $49 one-time (legacy alias: STRIPE_PRICE_INDIVIDUAL_149)
STRIPE_PRICE_ESSENTIAL=price_... # Essential Plan — $399/month (legacy alias: STRIPE_PRICE_FIRM_499)
STRIPE_PRICE_PROFESSIONAL=price_... # Professional Plan — $699/month
STRIPE_PRICE_ENTERPRISE=price_... # Enterprise Plan — $1,499/month (legacy alias: STRIPE_PRICE_PRO_1499)
# Local dev only — must stay unset in production (otherwise subscription plans reuse the single price):
# STRIPE_PRICE_TEST_ONETIME=price_...
# STRIPE_PRICE_TEST_SUBSCRIPTION=price_...

# Stripe Overage Price IDs (metered billing)
STRIPE_PRICE_PROFESSIONAL_OVERAGE=price_... # $29 per review
STRIPE_PRICE_ENTERPRISE_OVERAGE=price_... # $19 per review

# OpenAI
OPENAI_API_KEY=sk-...

# App
# Local: http://localhost:3000
# Production (Netlify): https://estimatereviewpro.com — absolute URL required for Stripe success_url;
# trailing slash optional (appAbsoluteUrl normalizes). Redeploy after changing.
NEXT_PUBLIC_APP_URL=http://localhost:3000
